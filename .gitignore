*.jld2

# Keep the published synthetic data files (intentionally tracked)
!data/synthetic/*.csv

# Keep pre-computed parameter vectors (intentionally tracked)
!output/estimates/*.csv

# Archives often used to store raw data
*.zip
*.7z
*.tar
*.gz
*.bz2
*.xz
*.rar

