## ------------------------------------------------------------
## Distributional_Dynamics/5_Code
## Keep source code tracked; ignore data, figures, and build artifacts.
## ------------------------------------------------------------

# macOS / editor noise
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Temp / logs
*.log
*.tmp
*.temp
*.swp
*.swo
*.bak
*~

# Julia artifacts
*.jl.cov
*.jl.mem
*.ji
.julia/

# X-13ARIMA-SEATS scratch output (dropped into cwd by seasonal adjustment)
Rout.*
Rout_*.html
gra_Rout/

# Python artifacts
__pycache__/
*.pyc
*.pyo

# Claude Code local settings
.claude/

# Common build/output folders
bld/
build/
dist/
out/
tmp/

## ----------------------
## Data files (common)
## ----------------------
*.csv
*.tsv
*.tab
*.dta
*.sav
*.por
*.sas7bdat
*.rds
*.feather
*.parquet
*.arrow
*.h5
*.hdf5
*.nc
*.mat
*.npy
*.npz
*.pkl
*.pickle
