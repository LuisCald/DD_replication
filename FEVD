function VAR_fit(y::AbstractArray, p::Int64)
    (T, K) = size(y)
    X = y
    y = transpose(y)
    Y = y[:, p+1:T]
    X = lagmatrix(X, p)'
    β = (Y * X') / (X * X')
    ϵ = Y - β * X
    Σ = ϵ * ϵ' / (T - p * K - 1)
    return diag(Σ)
end